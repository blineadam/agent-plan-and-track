{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"__SCRIPTS__/plan-gate.js\" --pre",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"__SCRIPTS__/plan-gate.js\" --post",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
