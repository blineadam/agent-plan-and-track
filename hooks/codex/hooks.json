{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat \"$HOME/.codex/core-rules.md\" \"$HOME/.codex/core-rules.local.md\" 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Refreshing standing rules"
          }
        ]
      }
    ]
  }
}
